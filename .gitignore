# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/

# Virtual environments
.venv/
venv/
env/
ENV/

# Environment variables / secrets
.env
*.env
!.env.example

# Raw scraped corpus (regenerated by ingestion)
data/raw/
data/processed/

# Vector store index — tracked in git so it deploys to Streamlit Cloud and the
# scheduled refresh can commit updates back. Only the transient build dirs and
# rollback snapshots are ignored.
vectorstore/index.tmp/
vectorstore/*.tmp/
vectorstore/backups/
*.chroma/
chroma_db/
*.faiss

# Scheduled-refresh runtime artifacts (Phase 10)
# last_refresh.json IS tracked (drives the UI "last updated" caption on deploy);
# only the local lockfile is ignored.
.refresh.lock

# Model caches
.cache/
models/

# IDE / OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# Streamlit
.streamlit/secrets.toml
